# Container image for any free Docker host (Hugging Face Spaces, Fly.io, Koyeb,
# Railway, or Render's Docker runtime). Build context is the app/ folder.
FROM node:20-slim AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM node:20-slim
WORKDIR /app
ENV NODE_ENV=production
# Bring the built client + server bundle and the production node_modules.
COPY --from=build /app/dist ./dist
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/package.json ./package.json
# Hosts inject PORT; the server reads it (defaults to 3000).
EXPOSE 3000
CMD ["npm", "start"]
