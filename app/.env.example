# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID (optional)
APP_SECRET=               # Application secret (optional)

# ── Database (OPTIONAL) ────────────────────────────────────────
# The app is fully stateless — conversation history and cart are kept on the
# client and sent with every request, so NO database is needed to run or
# deploy. This is only here for legacy seed scripts; leave it blank.
DATABASE_URL=             # (optional) MySQL connection string

# ── LLM provider ───────────────────────────────────────────────
# OpenRouter only. Use a free, tool-calling-capable model.
# Free models that worked at build time (pick one that responds for you):
#   openai/gpt-oss-120b:free      (fast, good tool use — default)
#   openai/gpt-oss-20b:free
#   google/gemma-4-31b-it:free
#   openrouter/free               (auto-routes across free models — most resilient)
# NOTE: free models rate-limit hard. For a reliable live demo, a small paid
# model (e.g. openai/gpt-4o-mini) via the same key is far more dependable.
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-oss-120b:free
