# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID (optional)
APP_SECRET=               # Application secret (optional)

# ── Database (OPTIONAL) ────────────────────────────────────────
# The app is fully stateless — conversation history and cart are kept on the
# client and sent with every request, so NO database is needed to run or
# deploy. This is only here for legacy seed scripts; leave it blank.
DATABASE_URL=             # (optional) MySQL connection string

# ── LLM provider ───────────────────────────────────────────────
# OpenRouter only. Use free, tool-calling-capable models.
# LLM_MODEL accepts a COMMA-SEPARATED FALLBACK CHAIN — if the first model is
# rate-limited (429), the agent automatically tries the next one. This is the
# zero-cost way to stay reliable on free models during a live demo.
# Free models that worked at build time:
#   openai/gpt-oss-120b:free      (fast, good tool use — default primary)
#   openai/gpt-oss-20b:free
#   openrouter/free               (auto-routes across free models — most resilient)
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-oss-120b:free,openai/gpt-oss-20b:free,openrouter/free
