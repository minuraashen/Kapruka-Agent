# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID (optional)
APP_SECRET=               # Application secret (optional)

# ── LLM providers (free, cross-provider fallback) ───────────────
# The agent tries each provider in order and falls through to the next on a
# rate-limit/error. Spanning DIFFERENT providers gives independent rate-limit
# buckets, so the chain keeps answering even when one provider throttles you.
#
# Format:  LLM_PROVIDERS=<provider>|<model>, <provider>|<model>, ...
# Known providers (all OpenAI-compatible): groq, nvidia, openrouter
# Each provider reads its key from the matching <PROVIDER>_API_KEY below.
#
# Order by tool-calling reliability first, then speed (Groq's LPU is fastest).
# Groq runs Qwen3 reliably; OpenRouter is the fallback. NOTE: OpenRouter has been
# retiring many ":free" model IDs (mid-2026) — verify slugs before relying on them:
#   groq        → https://console.groq.com/docs/models
#   openrouter  → https://openrouter.ai/models?max_price=0
LLM_PROVIDERS=groq|qwen/qwen3-32b, openrouter|qwen/qwen3.6-plus:free, openrouter|openai/gpt-oss-120b:free

# API keys — fill in only the providers you list above (no credit card needed).
GROQ_API_KEY=             # https://console.groq.com/keys
OPENROUTER_API_KEY=       # https://openrouter.ai/keys

# Optional base-URL overrides (defaults are the official endpoints):
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Legacy single-provider config (still supported) ─────────────
# If LLM_PROVIDERS is unset, the app falls back to these. LLM_MODEL accepts a
# comma-separated model fallback chain on a single provider.
# LLM_API_KEY=
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openai/gpt-oss-120b:free,openai/gpt-oss-20b:free,openrouter/free
